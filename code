    "REWARDFUN",
    "NEWTROLL",
    "KITT_RESET",
    "Sub2CaptainMaui",
    "DEVSCOOKING",
    "Sub2Fer999",
    "Enyu_is_Pro",
    "Magicbus",
    "JCWK",
    "Starcodeheo",
    "Bluxxy",
    "fudd10_v2",
    "SUB2GAMERROBOT_EXP1",
    "Sub2NoobMaster123",
    "Sub2UncleKizaru",
    "Sub2OfficialNoobie",
    "TheGreatAce",
    "Axiore",
    "StrawHatMaine"
}

local HNCHub = game:GetService("ReplicatedStorage")
-- Kiểm tra đường dẫn Remote (Blox Fruits thường dùng 'Redeem' hoặc 'ClaimCode')
local _hnc = HNCHub:WaitForChild("Remotes"):WaitForChild("Redeem")

task.wait(2)

for _, code in ipairs(HNC) do 
    pcall(function()
        local result = _hnc:InvokeServer(code)
        print("Đang nhập code: " .. code .. " | Trạng thái: " .. tostring(result))
    end)
    task.wait(2) -- Nghỉ một chút để tránh bị hệ thống chặn (Rate limit)
end
